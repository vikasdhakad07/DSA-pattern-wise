Approach 3: Two HashMaps
Intuition
Store unique elements of nums1 in map1.
Traverse nums2.
If element exists in map1, store it in map2.
map2 automatically removes duplicates.

Java
class Solution {
    public int[] intersection(int[] nums1, int[] nums2) {

        HashMap<Integer, Integer> map1 = new HashMap<>();
        HashMap<Integer, Integer> map2 = new HashMap<>();

        for (int num : nums1) {
            if (!map1.containsKey(num)) {
                map1.put(num, 1);
            }
        }

        for (int num : nums2) {
            if (map1.containsKey(num)) {
                map2.put(num, 1);
            }
        }

        int[] ans = new int[map2.size()];
        int index = 0;

        for (int num : map2.keySet()) {
            ans[index++] = num;
        }

        return ans;
    }
}
