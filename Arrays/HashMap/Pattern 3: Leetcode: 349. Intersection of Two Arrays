Approach 4: HashSet (Optimal)
Intuition
Store unique elements of nums1 in a HashSet.
Traverse nums2.
If element exists:
Add to result.
Remove from set to avoid duplicates.
Java
class Solution {
    public int[] intersection(int[] nums1, int[] nums2) {

        HashSet<Integer> set = new HashSet<>();

        for (int num : nums1) {
            set.add(num);
        }

        HashSet<Integer> result = new HashSet<>();

        for (int num : nums2) {

            if (set.contains(num)) {
                result.add(num);
                set.remove(num);
            }
        }

        int[] ans = new int[result.size()];
        int index = 0;

        for (int num : result) {
            ans[index++] = num;
        }

        return ans;
    }
}
