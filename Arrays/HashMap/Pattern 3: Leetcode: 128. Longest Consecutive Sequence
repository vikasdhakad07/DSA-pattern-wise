Approach 3: HashMap
Intuition

Store every number in a HashMap.

For every number:

Check whether num-1 exists.
If it doesn't, this is the start of a sequence.
Keep checking num+1, num+2...

Java
class Solution {
    public int longestConsecutive(int[] nums) {

        HashMap<Integer, Boolean> map = new HashMap<>();

        for (int num : nums) {
            map.put(num, true);
        }

        int longest = 0;

        for (int num : map.keySet()) {

            if (!map.containsKey(num - 1)) {

                int current = num;
                int streak = 1;

                while (map.containsKey(current + 1)) {
                    current++;
                    streak++;
                }

                longest = Math.max(longest, streak);
            }
        }

        return longest;
    }
}
