Approach 2: Binary Search on Answer (Optimal)
Intuition

Possible answers are sorted.

10 11 12 13 14 15 16 17 18 ... 32

❌ ❌ ❌ ❌ ❌ ❌ ❌ ❌ ✔ ✔ ✔ ✔

Binary Search finds the first valid maximum sum.

Your Code (Optimal)
class Solution {

    public int splitArray(int[] nums, int k) {

        int N = nums.length;

        int left = Arrays.stream(nums).max().getAsInt();
        int right = Arrays.stream(nums).sum();

        while (left < right) {

            int mid = left + (right - left) / 2;

            if (isPossible(nums, k, N, mid)) {

                right = mid;

            } else {

                left = mid + 1;
            }
        }

        return left;
    }

    public boolean isPossible(int arr[], int k, int N, int maxSum) {

        int count = 0;
        int currentSum = 0;

        for (int i = 0; i < N; i++) {

            currentSum += arr[i];

            if (currentSum > maxSum) {

                count++;
                currentSum = arr[i];
            }
        }

        count++;

        return count <= k;
    }
}
